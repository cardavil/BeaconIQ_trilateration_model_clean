<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Mode toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_tab_new_session"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/btn_teal"
                android:text="New Session"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btn_tab_history"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/btn_grey"
                android:text="History"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                app:backgroundTint="@null" />
        </LinearLayout>

        <!-- New Session container -->
        <LinearLayout
            android:id="@+id/session_form_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Form fields (hidden during recording) -->
            <LinearLayout
                android:id="@+id/form_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyst Name"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edit_analyst"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edit_border"
                    android:hint="Your name"
                    android:importantForAutofill="no"
                    android:inputType="textPersonName"
                    android:padding="10dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_dim"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Duration (5-600 seconds)"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edit_duration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edit_border"
                    android:fontFamily="monospace"
                    android:hint="60"
                    android:importantForAutofill="no"
                    android:inputType="number"
                    android:padding="10dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_dim"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Movement Mode"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/spinner_movement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/spinner_border"
                    android:padding="10dp"
                    android:popupBackground="@color/bg" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Room Name"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edit_room"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edit_border"
                    android:hint="Room name"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:padding="10dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_dim"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Phone Position"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/spinner_phone_position"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/spinner_border"
                    android:padding="10dp"
                    android:popupBackground="@color/bg" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp"
                    android:letterSpacing="0.08"
                    android:text="MODEL PARAMETERS"
                    android:textAllCaps="true"
                    android:textColor="@color/teal"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Model parameters (visible in all phases, editable in Phase II) -->
                <LinearLayout
                    android:id="@+id/model_params_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="TxPower (dBm, -100 to 0)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_tx_power"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="-59"
                        android:importantForAutofill="no"
                        android:inputType="numberSigned"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Path Loss N (1.0 to 6.0)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_path_loss"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="2.0"
                        android:importantForAutofill="no"
                        android:inputType="numberDecimal"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="RSSI Threshold (dBm, -120 to -20)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_rssi_threshold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="-100"
                        android:importantForAutofill="no"
                        android:inputType="numberSigned"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Kalman Q (0.001 – 1.0)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_kalman_q"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="0.05"
                        android:importantForAutofill="no"
                        android:inputType="numberDecimal"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Kalman R (0.001 – 5.0)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_kalman_r"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="0.25"
                        android:importantForAutofill="no"
                        android:inputType="numberDecimal"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="RSSI Buffer Size (1 – 100)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_rssi_buffer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="20"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="RSSI Time Window ms (500 – 30000)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_rssi_window"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="8000"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Scale Factor (0.1 – 50.0)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_scale_factor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="5.0"
                        android:importantForAutofill="no"
                        android:inputType="numberDecimal"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Beacon Timeout ms (1000 – 30000)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_beacon_timeout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="4000"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Eval Interval ms (500 – 30000)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edit_eval_interval"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_border"
                        android:fontFamily="monospace"
                        android:hint="3000"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_dim"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/solver_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Solver"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spinner_solver"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/spinner_border"
                        android:padding="10dp"
                        android:popupBackground="@color/bg" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Notes"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edit_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/edit_border"
                    android:gravity="top"
                    android:hint="Observations (metal shelf, open door, people walking...)"
                    android:importantForAutofill="no"
                    android:inputType="textMultiLine"
                    android:maxLines="3"
                    android:minLines="3"
                    android:padding="10dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_dim"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btn_reset_defaults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/btn_grey"
                    android:text="Reset Defaults"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"
                    app:backgroundTint="@null" />
            </LinearLayout>

            <!-- Model status panel (visible during recording) -->
            <LinearLayout
                android:id="@+id/model_status_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_closest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Closest: ---"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text="State: SEARCHING"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_beacon_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text="Beacons: 0 / 3 required"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_kalman_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text="Kalman: OFF (bypassed in BeaconSample)"
                    android:textColor="@color/text_dim"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_solver_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text="Solver: findClosestBeacon (no x,y calculated)"
                    android:textColor="@color/text_dim"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_engine_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:text="ProximityEngine: instantiated, never called"
                    android:textColor="@color/text_dim"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- 2D positioning canvas (visible during recording) -->
            <com.beaconiq.trilateration.ui.PositioningCanvasView
                android:id="@+id/positioning_canvas"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="12dp" />

            <!-- Start/Stop button (outside form_section, stays visible during recording) -->
            <Button
                android:id="@+id/btn_start_session"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/btn_teal"
                android:enabled="false"
                android:text="Start Session"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />
        </LinearLayout>

        <!-- History container -->
        <LinearLayout
            android:id="@+id/session_history_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/history_open_console"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="?attr/selectableItemBackground"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Open Console ↗"
                android:textColor="@color/teal"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/history_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tap History to load sessions"
                android:textColor="@color/text_dim"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/history_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
